<ui:FluentWindow
    x:Class="WslManager.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:WslManager.ViewModels"
    Title="WSL Manager"
    Width="760"
    Height="560"
    MinWidth="620"
    MinHeight="400"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.DataContext>
        <vm:MainViewModel />
    </ui:FluentWindow.DataContext>

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Barra de título -->
        <ui:TitleBar Grid.Row="0" Title="WSL Manager">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="ServerMultiple20" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Toolbar -->
        <StackPanel
            Grid.Row="1"
            Margin="16,8,16,8"
            Orientation="Horizontal">
            <ui:Button
                Appearance="Secondary"
                Command="{Binding RefreshCommand}"
                Content="Atualizar"
                Icon="{ui:SymbolIcon ArrowClockwise20}"
                IsEnabled="{Binding IsIdle}" />
            <ui:Button
                Margin="8,0,0,0"
                Appearance="Danger"
                Command="{Binding ShutdownAllCommand}"
                Content="Desligar tudo"
                Icon="{ui:SymbolIcon Power20}"
                IsEnabled="{Binding IsIdle}"
                ToolTip="wsl --shutdown: derruba a VM inteira, todas as distros" />
            <ui:ProgressRing
                Width="22"
                Height="22"
                Margin="12,0,0,0"
                IsIndeterminate="True"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <!-- Lista de distros -->
        <ScrollViewer Grid.Row="2" Margin="16,0,16,0">
            <StackPanel>
                <ui:InfoBar
                    Title="Nenhuma distro encontrada"
                    IsClosable="False"
                    IsOpen="{Binding HasNoDistros}"
                    Message="Instale uma com:  wsl --install -d Ubuntu-24.04"
                    Severity="Informational" />

                <ItemsControl ItemsSource="{Binding Distros}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DistroViewModel}">
                            <ui:Card Margin="0,0,0,10" Padding="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Indicador de estado -->
                                    <Ellipse
                                        Grid.Column="0"
                                        Width="10"
                                        Height="10"
                                        Margin="2,0,12,0"
                                        VerticalAlignment="Center"
                                        ToolTip="{Binding StateText}">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#6E6E6E" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Fill" Value="#4CC26B" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <!-- Nome + metadados -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Text="{Binding Name}" />
                                            <Border
                                                Margin="8,0,0,0"
                                                Padding="6,1"
                                                VerticalAlignment="Center"
                                                Background="#33569CD6"
                                                CornerRadius="4"
                                                Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                                                <TextBlock FontSize="11" Text="padrão" />
                                            </Border>
                                            <Border
                                                Margin="6,0,0,0"
                                                Padding="6,1"
                                                VerticalAlignment="Center"
                                                Background="#33D67E56"
                                                CornerRadius="4"
                                                Visibility="{Binding IsSystem, Converter={StaticResource BoolToVis}}">
                                                <TextBlock FontSize="11" Text="sistema" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                            <Run Text="{Binding StateText, Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding VersionText, Mode=OneWay}" />
                                            <Run Text=" · disco: " />
                                            <Run Text="{Binding VhdSizeText, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Ações -->
                                    <StackPanel
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <ui:Button
                                            Appearance="Secondary"
                                            Command="{Binding OpenTerminalCommand}"
                                            Icon="{ui:SymbolIcon WindowConsole20}"
                                            ToolTip="Abrir terminal" />
                                        <ui:Button
                                            Margin="6,0,0,0"
                                            Appearance="Secondary"
                                            Command="{Binding OpenExplorerCommand}"
                                            Icon="{ui:SymbolIcon FolderOpen20}"
                                            ToolTip="Abrir no Explorer (só com a distro em execução)" />
                                        <ui:Button
                                            Margin="6,0,0,0"
                                            Appearance="Secondary"
                                            Command="{Binding SetDefaultCommand}"
                                            Icon="{ui:SymbolIcon Star20}"
                                            ToolTip="Definir como padrão" />
                                        <ui:Button
                                            Margin="12,0,0,0"
                                            Appearance="Success"
                                            Command="{Binding WakeCommand}"
                                            Content="Iniciar"
                                            Icon="{ui:SymbolIcon Play20}" />
                                        <ui:Button
                                            Margin="6,0,0,0"
                                            Appearance="Danger"
                                            Command="{Binding TerminateCommand}"
                                            Content="Encerrar"
                                            Icon="{ui:SymbolIcon Stop20}" />
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Barra de status -->
        <Border
            Grid.Row="3"
            Padding="16,6"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <TextBlock
                FontSize="12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="{Binding StatusText}" />
        </Border>
    </Grid>
</ui:FluentWindow>
