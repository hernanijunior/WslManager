<ui:FluentWindow
    x:Class="WslManager.Views.DeleteDistroDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Apagar distro"
    Width="500"
    Height="430"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="Apagar distro"
            CanMaximize="False"
            ShowMaximize="False"
            ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="20,8,20,0">
            <ui:InfoBar
                x:Name="WarnBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Error"
                Title="Ação irreversível" />

            <TextBlock
                Margin="0,14,0,0"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Isto apaga permanentemente a distro e TODOS os seus dados. Não há como desfazer."
                TextWrapping="Wrap" />

            <TextBlock x:Name="DetailText" Margin="0,10,0,0" TextWrapping="Wrap" />

            <CheckBox
                x:Name="ExportCheck"
                Margin="0,16,0,0"
                Content="Exportar backup (.tar) antes de apagar"
                IsChecked="True" />

            <TextBlock
                Margin="0,16,0,4"
                Text="Para confirmar, digite o nome exato da distro:" />
            <ui:TextBox
                x:Name="ConfirmBox"
                TextChanged="OnConfirmChanged" />
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Margin="20,16,20,16"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                Appearance="Secondary"
                Click="OnCancel"
                Content="Cancelar" />
            <ui:Button
                x:Name="DeleteButton"
                Margin="8,0,0,0"
                Appearance="Danger"
                Click="OnDelete"
                Content="Apagar"
                Icon="{ui:SymbolIcon Delete24}"
                IsEnabled="False" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
