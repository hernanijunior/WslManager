<Page
    x:Class="WslManager.Views.Pages.DistrosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:WslManager.ViewModels"
    Title="Distros"
    d:DesignHeight="500"
    d:DesignWidth="700"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="16,8,16,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,8"
            Orientation="Horizontal">
            <ui:Button
                Appearance="Primary"
                Command="{Binding NewDistroCommand}"
                Content="Nova distro"
                Icon="{ui:SymbolIcon Add24}"
                IsEnabled="{Binding IsIdle}"
                ToolTip="Criar uma distro a partir do catálogo, de um arquivo ou clonando" />
            <ui:Button
                Margin="8,0,0,0"
                Appearance="Secondary"
                Command="{Binding RefreshCommand}"
                Content="Atualizar"
                Icon="{ui:SymbolIcon ArrowClockwise20}"
                IsEnabled="{Binding IsIdle}" />
            <ui:Button
                Margin="8,0,0,0"
                Appearance="Danger"
                Command="{Binding ShutdownAllCommand}"
                Content="Desligar tudo"
                Icon="{ui:SymbolIcon Power20}"
                IsEnabled="{Binding IsIdle}"
                ToolTip="wsl --shutdown: derruba a VM inteira, todas as distros" />
            <ui:ProgressRing
                Width="22"
                Height="22"
                Margin="12,0,0,0"
                IsIndeterminate="True"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <!-- Lista de distros -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ui:InfoBar
                    Title="Nenhuma distro encontrada"
                    IsClosable="False"
                    IsOpen="{Binding HasNoDistros}"
                    Message="Instale uma com:  wsl --install -d Ubuntu-24.04"
                    Severity="Informational" />

                <ItemsControl ItemsSource="{Binding Distros}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DistroViewModel}">
                            <ui:Card Margin="0,0,0,10" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Área clicável: abre o detalhe da distro -->
                                    <ui:Button
                                        Grid.Column="0"
                                        Padding="10"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Appearance="Transparent"
                                        Command="{Binding OpenDetailCommand}"
                                        Cursor="Hand"
                                        ToolTip="Ver detalhes">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Indicador de estado -->
                                            <Ellipse
                                                Grid.Column="0"
                                                Width="10"
                                                Height="10"
                                                Margin="2,0,12,0"
                                                VerticalAlignment="Center"
                                                ToolTip="{Binding StateText}">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#6E6E6E" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Fill" Value="#4CC26B" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <!-- Nome + metadados -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock
                                                        FontSize="15"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Name}" />
                                                    <Border
                                                        Margin="8,0,0,0"
                                                        Padding="6,1"
                                                        VerticalAlignment="Center"
                                                        Background="#33569CD6"
                                                        CornerRadius="4"
                                                        Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock FontSize="11" Text="padrão" />
                                                    </Border>
                                                    <Border
                                                        Margin="6,0,0,0"
                                                        Padding="6,1"
                                                        VerticalAlignment="Center"
                                                        Background="#33D67E56"
                                                        CornerRadius="4"
                                                        Visibility="{Binding IsSystem, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock FontSize="11" Text="sistema" />
                                                    </Border>
                                                    <ui:SymbolIcon
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Filled="True"
                                                        Foreground="#E9A23B"
                                                        Symbol="Warning24"
                                                        ToolTip="Disco acima do limite configurado"
                                                        Visibility="{Binding DiskAlert, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontSize="12"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                    <Run Text="{Binding StateText, Mode=OneWay}" />
                                                    <Run Text=" · " />
                                                    <Run Text="{Binding VersionText, Mode=OneWay}" />
                                                    <Run Text=" · disco: " />
                                                    <Run Text="{Binding VhdSizeText, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </ui:Button>

                                    <!-- Ações rápidas -->
                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <ui:Button
                                            Appearance="Secondary"
                                            Command="{Binding OpenTerminalCommand}"
                                            Icon="{ui:SymbolIcon WindowConsole20}"
                                            ToolTip="Abrir terminal" />
                                        <ui:Button
                                            Margin="12,0,0,0"
                                            Appearance="Success"
                                            Command="{Binding WakeCommand}"
                                            Content="Iniciar"
                                            Icon="{ui:SymbolIcon Play20}" />
                                        <ui:Button
                                            Margin="6,0,0,0"
                                            Appearance="Danger"
                                            Command="{Binding TerminateCommand}"
                                            Content="Encerrar"
                                            Icon="{ui:SymbolIcon Stop20}" />
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
