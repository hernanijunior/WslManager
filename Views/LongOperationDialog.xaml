<ui:FluentWindow
    x:Class="WslManager.Views.LongOperationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Operação em andamento"
    Width="460"
    Height="210"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="{Binding Title}"
            CanMaximize="False"
            ShowClose="False"
            ShowMaximize="False"
            ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="20,8,20,0" VerticalAlignment="Center">
            <TextBlock
                FontSize="14"
                Text="{Binding Status}"
                TextWrapping="Wrap" />
            <ProgressBar
                Margin="0,14,0,0"
                IsIndeterminate="True" />
            <TextBlock
                Margin="0,8,0,0"
                FontSize="12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="{Binding SizeText}" />
        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="20,12"
            HorizontalAlignment="Stretch">
            <ui:Button
                HorizontalAlignment="Right"
                Appearance="Secondary"
                Command="{Binding CancelCommand}"
                Content="Cancelar"
                Icon="{ui:SymbolIcon Dismiss24}" />
        </Border>
    </Grid>
</ui:FluentWindow>
